<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clickable="true">

    <!-- Collapsed Bubble -->
    <LinearLayout
        android:id="@+id/collapsed_bubble"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bubble_background"
        android:elevation="8dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/turn_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="turns"
            android:textColor="#90CAF9"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Expanded Panel -->
    <androidx.cardview.widget.CardView
        android:id="@+id/expanded_panel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#E01A237E">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Battle Logger"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/turn_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Turn 0"
                    android:textColor="#90CAF9"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btn_minimize"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="@null"
                    android:scaleType="center"
                    android:contentDescription="Minimize"
                    android:tint="#FFFFFF" />

                <ImageButton
                    android:id="@+id/btn_close"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:background="@null"
                    android:scaleType="center"
                    android:contentDescription="Stop"
                    android:tint="#EF5350" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3FFFFFFF"
                android:layout_marginVertical="8dp" />

            <!-- My Side -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— MY POKEMON —"
                android:textColor="#64B5F6"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_my_pokemon"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:hint="My Pokémon"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:textSize="12sp"
                android:background="#33000000"
                android:paddingHorizontal="8dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/et_my_move"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:hint="Move used"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:textSize="12sp"
                android:background="#33000000"
                android:paddingHorizontal="8dp"
                android:singleLine="true"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/my_hp_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My HP: 100%"
                android:textColor="#A5D6A7"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <Button
                    android:id="@+id/hp_my_25"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="-25"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="0dp"
                    style="@style/HpButton" />

                <Button
                    android:id="@+id/hp_my_50"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="-50"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="0dp"
                    style="@style/HpButton" />

                <Button
                    android:id="@+id/hp_my_75"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="-75"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="0dp"
                    style="@style/HpButton" />

                <Button
                    android:id="@+id/hp_my_100"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="KO"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="0dp"
                    style="@style/HpButtonDeath" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3FFFFFFF"
                android:layout_marginVertical="8dp" />

            <!-- Opponent Side -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— OPPONENT —"
                android:textColor="#EF9A9A"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_opp_pokemon"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:hint="Opponent Pokémon"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:textSize="12sp"
                android:background="#33000000"
                android:paddingHorizontal="8dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/et_opp_move"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:hint="Move used"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:textSize="12sp"
                android:background="#33000000"
                android:paddingHorizontal="8dp"
                android:singleLine="true"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/opp_hp_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opp HP: 100%"
                android:textColor="#EF9A9A"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <Button
                    android:id="@+id/hp_opp_25"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="-25"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="0dp"
                    style="@style/HpButton" />

                <Button
                    android:id="@+id/hp_opp_50"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="-50"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="0dp"
                    style="@style/HpButton" />

                <Button
                    android:id="@+id/hp_opp_75"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="-75"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="0dp"
                    style="@style/HpButton" />

                <Button
                    android:id="@+id/hp_opp_100"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="KO"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="0dp"
                    style="@style/HpButtonDeath" />
            </LinearLayout>

            <!-- Add Turn Button -->
            <Button
                android:id="@+id/btn_add_turn"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="+ LOG THIS TURN"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:backgroundTint="#1565C0" />

            <!-- Battle Log -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— RECENT LOG —"
                android:textColor="#78909C"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:id="@+id/log_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp" />

            <!-- Notes input -->
            <EditText
                android:id="@+id/et_notes"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:hint="Notes (optional)"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:textSize="11sp"
                android:background="#33000000"
                android:paddingHorizontal="8dp"
                android:singleLine="true"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
